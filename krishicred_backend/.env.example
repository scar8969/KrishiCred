# Environment Configuration for KrishiCred Backend

# Application
APP_NAME=KrishiCred API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=krishicred
POSTGRES_PASSWORD=krishicred
POSTGRES_DB=krishicred
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Google Earth Engine
GEE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GEE_PROJECT_ID=your-project-id

# Satellite Processing
FIRE_CONFIDENCE_THRESHOLD=80.0
FIRE_DETECTION_RADIUS_KM=5
SATELLITE_CHECK_INTERVAL_HOURS=6
MAX_FIRE_AGE_DAYS=1

# Geospatial (Punjab bounding box)
PUNJAB_BOUNDING_MIN_LAT=29.5
PUNJAB_BOUNDING_MAX_LAT=32.5
PUNJAB_BOUNDING_MIN_LON=73.5
PUNJAB_BOUNDING_MAX_LON=76.5

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_TEMPLATE_NAMESPACE=krishicred

# Carbon Credits
CARBON_CREDIT_PER_TON_CO2E=1.0
STUBBLE_TO_CO2_CONVERSION_RATIO=2.5
MIN_CREDIT_ISSUANCE_TONS=0.1
CREDIT_VERIFICATION_PERIOD_DAYS=90
CREDIT_PRICE_PER_TON_INR=2500.0

# Routing
MAX_COLLECTION_DISTANCE_KM=50
MIN_VEHICLE_CAPACITY_TONS=2.0
MAX_VEHICLE_CAPACITY_TONS=15.0
ROUTING_OPTIMIZATION_TIMEOUT_SEC=300
AVERAGE_TRANSPORT_COST_PER_KM=15.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# External APIs
MAPBOX_API_KEY=your_mapbox_api_key_here
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
